APP_NAME=DietTracker
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_URL=http://your-vps-ip
APP_DEBUG=false
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=dt
DB_USERNAME=dt
# DB_PASSWORD via secrets/db_password.txt, not here

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

SANCTUM_STATEFUL_DOMAINS=
